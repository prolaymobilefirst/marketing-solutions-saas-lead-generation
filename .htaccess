Options -MultiViews
RewriteEngine On

# Cache-Control tagging — env vars consumed by the mod_headers block at the
# bottom of this file. Mirrors the Netlify (_headers) / Vercel (vercel.json)
# cache policy so Apache/Hostinger gets the same behaviour. Must run before
# any [L]-flagged rule below: env vars are request-scoped and survive later
# internal rewrites, but a rule never reached can't set one.
RewriteRule ^$ - [E=CACHE_HTML:1]
RewriteRule ^(css|js|assets)/ - [E=CACHE_IMMUTABLE:1]
RewriteRule ^partials/ - [E=CACHE_SHORT:1]
RewriteRule ^(admin|api-php|api)/ - [E=CACHE_NONE:1]

# Lead funnel API — same public paths as the Netlify/Vercel functions, so
# js/webhook.js needs no per-host branching. Must come before the generic
# /page → /page.html rule below. The PHP twins live in api-php/, not
# api/, because Vercel's build scans api/ and rejects a .js and .php file
# sharing the same basename as a "conflicting path" — see api-php/.
RewriteRule ^api/submit-lead$ api-php/submit-lead.php [L]
RewriteRule ^api/download-pdf$ api-php/download-pdf.php [L]

# The lead-magnet PDF and admin data must never be reachable as static
# files — same defense-in-depth redirect already used on Netlify/Vercel.
RewriteRule ^server/ /? [R=302,L]
RewriteRule ^downloads/ /? [R=302,L]

# Redirect /index.html → / (301 permanent) — must precede the generic
# page.html rule below, which would otherwise send this to /index.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^ /? [R=301,L]

# Redirect /page.html → /page (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve /page → /page.html (no redirect loop)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [E=CACHE_HTML:1,L]

# Cache-Control headers — mirrors the Netlify (_headers) / Vercel (vercel.json)
# cache policy: 1-year immutable for versioned assets, short cache for
# partials (so site-wide CMS edits propagate quickly), must-revalidate for
# HTML pages, and no-store for dynamic/admin endpoints.
<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000, immutable" env=CACHE_IMMUTABLE
  Header set Cache-Control "public, max-age=300" env=CACHE_SHORT
  Header set Cache-Control "public, max-age=0, must-revalidate" env=CACHE_HTML
  Header set Cache-Control "no-store" env=CACHE_NONE

  # Security headers — mirrors the Netlify (_headers) / Vercel (vercel.json)
  # security policy, applied to every response regardless of cache tagging.
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
</IfModule>
