# Security headers — applied to every response
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff

# Netlify cache-control headers
# Versioned assets: cache 1 year (immutable — filenames must change on update)
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages: always revalidate (CDN may cache but must check for freshness)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Root index
/
  Cache-Control: public, max-age=0, must-revalidate

# Partials: short cache so updates propagate quickly
/partials/*
  Cache-Control: public, max-age=300

# Admin-editable content JSON (affiliate links, blog metadata): same short
# cache as partials — edits made in the admin panel must reach visitors fast
/content/*
  Cache-Control: public, max-age=300
